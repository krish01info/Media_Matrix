<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme — Dark -->
    <style name="Base.Theme.Media_Matrix" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_surface</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/secondary_surface</item>

        <!-- Surface / Background -->
        <item name="android:colorBackground">@color/surface_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorSurfaceVariant">@color/surface_medium</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Outline -->
        <item name="colorOutline">@color/border</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/surface_darkest</item>
        <item name="android:navigationBarColor">@color/surface_darkest</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/surface_dark</item>

        <!-- Bottom Nav -->
        <item name="bottomNavigationStyle">@style/Widget.MediaMatrix.BottomNavigation</item>
    </style>

    <style name="Theme.Media_Matrix" parent="Base.Theme.Media_Matrix" />

    <!-- Bottom Navigation Style -->
    <style name="Widget.MediaMatrix.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/bottom_nav_bg</item>
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.MediaMatrix.BottomNav.Indicator</item>
    </style>

    <style name="Widget.MediaMatrix.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_surface</item>
        <item name="android:width">44dp</item>
        <item name="android:height">32dp</item>
    </style>

    <!-- Toolbar Style -->
    <style name="Widget.MediaMatrix.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/transparent</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

    <!-- Card Glass Style -->
    <style name="Widget.MediaMatrix.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_medium</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.MediaMatrix.Card.Glass">
        <item name="cardBackgroundColor">@color/card_glass</item>
        <item name="strokeColor">@color/border_light</item>
    </style>

    <!-- Chip Style -->
    <style name="Widget.MediaMatrix.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/surface_light</item>
        <item name="chipStrokeColor">@color/border</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="chipCornerRadius">@dimen/radius_pill</item>
        <item name="chipMinHeight">@dimen/chip_height</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <style name="Widget.MediaMatrix.Chip.Active">
        <item name="chipBackgroundColor">@color/primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="chipStrokeColor">@color/primary</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.MediaMatrix.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="cornerRadius">@dimen/radius_md</item>
    </style>

    <style name="Widget.MediaMatrix.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border_light</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">@dimen/radius_md</item>
    </style>

    <!-- Text Input Style -->
    <style name="Widget.MediaMatrix.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_light</item>
        <item name="boxStrokeColor">@color/border_light</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
    </style>

    <!-- Navigation Drawer -->
    <style name="Widget.MediaMatrix.DrawerLayout" parent="">
        <item name="android:background">@color/surface_dark</item>
    </style>

    <!-- Section Header -->
    <style name="TextAppearance.MediaMatrix.SectionTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_title_lg</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.MediaMatrix.SectionAction" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <!-- Badge Styles -->
    <style name="Widget.MediaMatrix.Badge.Truth" parent="">
        <item name="android:background">@drawable/bg_truth_badge</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="Widget.MediaMatrix.Badge.Live" parent="">
        <item name="android:background">@drawable/bg_live_badge</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_overline</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="Widget.MediaMatrix.Badge.Premium" parent="">
        <item name="android:background">@drawable/bg_premium_badge</item>
        <item name="android:textColor">@color/surface_darkest</item>
        <item name="android:textSize">@dimen/text_overline</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>