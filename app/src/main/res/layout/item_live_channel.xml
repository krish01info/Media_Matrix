<?xml version="1.0" encoding="utf-8"?>
<!--
    item_live_channel.xml  — Card shown in the channel list on the Live Channels screen.
    Displays logo, channel name, country, and a pulsing LIVE badge.
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/channel_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/surface_medium"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md">

        <!-- Channel Logo -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp">

            <ImageView
                android:id="@+id/channel_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/surface_light"
                android:contentDescription="Channel logo"
                android:padding="6dp"
                android:scaleType="fitCenter"
                app:cardCornerRadius="@dimen/radius_md" />

        </FrameLayout>

        <!-- Channel Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/channel_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/channel_country"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxs"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_label" />

            <TextView
                android:id="@+id/channel_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxs"
                android:background="@drawable/bg_chip"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingEnd="8dp"
                android:paddingBottom="2dp"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_overline" />

        </LinearLayout>

        <!-- LIVE badge -->
        <TextView
            android:id="@+id/channel_live_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_live_badge"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp"
            android:text="@string/live"
            android:textColor="@color/white"
            android:textSize="@dimen/text_overline"
            android:textStyle="bold" />

        <!-- Play arrow -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:contentDescription="Play"
            android:src="@drawable/ic_play"
            app:tint="@color/text_tertiary" />

    </LinearLayout>

    <!-- Selection indicator stripe on the left -->
    <View
        android:id="@+id/selection_indicator"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/primary"
        android:visibility="gone" />

</androidx.cardview.widget.CardView>
