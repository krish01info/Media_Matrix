<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="@dimen/spacing_md"
    android:layout_marginBottom="@dimen/spacing_sm">

    <!-- Time + Live indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/developing_live_dot"
            android:layout_width="@dimen/live_dot_size"
            android:layout_height="@dimen/live_dot_size"
            android:background="@drawable/bg_live_dot" />

        <TextView
            android:id="@+id/developing_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:textColor="@color/text_tertiary"
            android:textSize="@dimen/text_overline" />
    </LinearLayout>

    <TextView
        android:id="@+id/developing_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_body_lg"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/developing_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:ellipsize="end"
        android:maxLines="3"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_body" />
</LinearLayout>
