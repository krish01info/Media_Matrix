<?xml version="1.0" encoding="utf-8"?>
<!--
    item_live_channel_home.xml  — Compact horizontal card shown on the Home screen
    "Live Now" section. Shows the channel logo + name + pulsing LIVE dot.
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="150dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/spacing_md"
    app:cardBackgroundColor="@color/surface_medium"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Logo area with gradient overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="90dp">

            <ImageView
                android:id="@+id/home_channel_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/surface_light"
                android:contentDescription="Channel"
                android:padding="12dp"
                android:scaleType="fitCenter" />

            <!-- Gradient overlay from bottom -->
            <View
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_bottom_overlay" />

            <!-- Pulsing LIVE dot -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="@dimen/spacing_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/live_dot"
                    android:layout_width="@dimen/live_dot_size"
                    android:layout_height="@dimen/live_dot_size"
                    android:background="@drawable/bg_live_dot" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/live"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_overline"
                    android:textStyle="bold" />
            </LinearLayout>

        </FrameLayout>

        <!-- Channel name -->
        <TextView
            android:id="@+id/home_channel_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:padding="@dimen/spacing_sm"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_label"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
