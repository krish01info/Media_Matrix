<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_newspaper_reader.xml
    Full-screen WebView reader for a newspaper website.
    Has a branded top bar showing the newspaper name + close/share buttons.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <!-- ── Top Bar ──────────────────────────────────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/reader_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_darkest"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- Close button -->
            <ImageButton
                android:id="@+id/btn_reader_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                android:padding="8dp"
                android:src="@drawable/ic_back"
                app:tint="@color/text_primary" />

            <!-- Logo + Name -->
            <ImageView
                android:id="@+id/reader_logo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:contentDescription="Logo"
                android:padding="2dp"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/reader_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body_lg"
                android:textStyle="bold" />

            <!-- Progress chip -->
            <TextView
                android:id="@+id/reader_live_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_live_badge"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:text="LIVE"
                android:textColor="@color/white"
                android:textSize="@dimen/text_overline"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Open in browser -->
            <ImageButton
                android:id="@+id/btn_open_browser"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Open in browser"
                android:padding="8dp"
                android:src="@drawable/ic_share"
                app:tint="@color/text_secondary" />

        </LinearLayout>

        <!-- Page load progress bar -->
        <ProgressBar
            android:id="@+id/reader_progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/primary"
            android:visibility="visible" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── WebView ───────────────────────────────────────────────── -->
    <WebView
        android:id="@+id/reader_web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- ── Loading overlay ──────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/reader_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/surface_dark"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <ImageView
            android:id="@+id/loading_logo"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:contentDescription="Loading"
            android:padding="8dp"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/loading_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_title"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Opening newspaper…"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/primary" />

    </LinearLayout>

    <!-- ── Error State ───────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/reader_error_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/surface_dark"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📡"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Unable to load newspaper"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_title"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Check your internet connection and try again"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />

        <TextView
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_gradient_primary"
            android:paddingStart="24dp"
            android:paddingTop="12dp"
            android:paddingEnd="24dp"
            android:paddingBottom="12dp"
            android:text="@string/retry"
            android:textColor="@color/surface_dark"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
