<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/spacing_md"
    app:cardBackgroundColor="@color/surface_medium"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="120dp">

            <ImageView
                android:id="@+id/stream_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/surface_light"
                android:contentDescription="Stream"
                android:scaleType="centerCrop" />

            <!-- LIVE Badge -->
            <TextView
                android:id="@+id/stream_live_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="@dimen/spacing_sm"
                android:background="@drawable/bg_live_badge"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingEnd="8dp"
                android:paddingBottom="2dp"
                android:text="@string/live"
                android:textColor="@color/white"
                android:textSize="@dimen/text_overline"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Play button overlay -->
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_chip"
                android:contentDescription="Play"
                android:padding="8dp"
                android:src="@drawable/ic_play"
                app:tint="@color/primary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <TextView
                android:id="@+id/stream_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/stream_listeners"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxs"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_label" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
