<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xxl">

    <!-- Back button -->
    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="start"
        android:layout_marginBottom="@dimen/spacing_xxl"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:src="@drawable/ic_back"
        app:tint="@color/text_secondary" />

    <!-- Album Art -->
    <androidx.cardview.widget.CardView
        android:layout_width="@dimen/player_art_size"
        android:layout_height="@dimen/player_art_size"
        app:cardCornerRadius="@dimen/radius_xl"
        app:cardElevation="8dp">

        <ImageView
            android:id="@+id/player_art"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/surface_medium"
            android:contentDescription="Album Art"
            android:scaleType="centerCrop" />
    </androidx.cardview.widget.CardView>

    <!-- Title -->
    <TextView
        android:id="@+id/player_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xxxl"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_title_lg"
        android:textStyle="bold" />

    <!-- Source -->
    <TextView
        android:id="@+id/player_source"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_body" />

    <!-- Live Badge -->
    <TextView
        android:id="@+id/player_live_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:background="@drawable/bg_live_badge"
        android:paddingStart="12dp"
        android:paddingTop="4dp"
        android:paddingEnd="12dp"
        android:paddingBottom="4dp"
        android:text="● LIVE"
        android:textColor="@color/white"
        android:textSize="@dimen/text_label"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Play/Pause Button -->
    <ImageButton
        android:id="@+id/btn_play_pause"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="@dimen/spacing_xxxl"
        android:background="@drawable/bg_gradient_primary"
        android:contentDescription="Play/Pause"
        android:padding="20dp"
        android:src="@drawable/ic_play"
        app:tint="@color/text_on_primary" />

</LinearLayout>
