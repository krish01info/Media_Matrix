<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_live_channels.xml
    ─────────────────────────
    Layout:
    ┌────────────────────────────────────────┐
    │  Header: "Live News Channels"          │
    │  Category chips (All / Intl / Indian…) │
    │  ┌──────────────────────────────────┐  │
    │  │  WebView  —  YouTube embed       │  │
    │  │  (16:9 aspect ratio)             │  │
    │  └──────────────────────────────────┘  │
    │  Channel name + country (now playing)  │
    │  ──────────────────────────────────    │
    │  RecyclerView  —  channel list         │
    └────────────────────────────────────────┘
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- ── Header ──────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_lg"
                android:layout_marginEnd="@dimen/spacing_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="Live TV"
                    android:src="@drawable/ic_live_tv"
                    app:tint="@color/live_red" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:text="@string/section_live_channels"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_headline"
                    android:textStyle="bold" />

                <!-- Pulsing red live indicator -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/live_pulse_dot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_live_dot" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/live"
                        android:textColor="@color/live_red"
                        android:textSize="@dimen/text_label"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- ── Category Filter Chips ───────────────────────── -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:clipToPadding="false"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/category_chips_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

            </HorizontalScrollView>

            <!-- ── WebView Player  ─────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_lg"
                android:layout_marginEnd="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/black"
                app:cardCornerRadius="@dimen/radius_xl"
                app:cardElevation="0dp">

                <!-- 16:9 aspect — width=match_parent, height via ratio -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- The WebView embedded in an aspect-ratio container -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <WebView
                            android:id="@+id/web_view_player"
                            android:layout_width="match_parent"
                            android:layout_height="220dp" />

                    </LinearLayout>

                    <!-- Loading overlay -->
                    <FrameLayout
                        android:id="@+id/player_loading_overlay"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:background="@color/surface_darkest">

                        <ProgressBar
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:indeterminateTint="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="64dp"
                            android:text="Loading channel…"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_label" />

                    </FrameLayout>

                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Now Playing Info ────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginEnd="@dimen/spacing_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="4dp"
                    android:layout_height="36dp"
                    android:background="@color/primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/now_playing_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/now_playing"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_overline"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/now_playing_channel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_lg"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/now_playing_country"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_label" />

                </LinearLayout>

                <!-- Open in YouTube button -->
                <TextView
                    android:id="@+id/btn_open_youtube"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="Open in YouTube"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_label"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ── Divider ─────────────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_lg"
                android:layout_marginEnd="@dimen/spacing_lg"
                android:background="@color/border" />

            <!-- ── Channel List header ─────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_lg"
                android:layout_marginEnd="@dimen/spacing_lg"
                android:text="@string/section_all_channels"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_label"
                android:textStyle="bold" />

            <!-- ── Channel RecyclerView ────────────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/channels_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
