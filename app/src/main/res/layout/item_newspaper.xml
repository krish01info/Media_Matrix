<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/newspaper_card_width"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/spacing_md"
    app:cardBackgroundColor="@color/surface_medium"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/newspaper_cover"
            android:layout_width="match_parent"
            android:layout_height="@dimen/newspaper_card_height"
            android:background="@color/surface_light"
            android:contentDescription="Newspaper Cover"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/newspaper_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="@dimen/spacing_sm"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_label" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
